# Thinky Dev Sandbox — Environment Variables
# Copy to .env and fill in your values.
# This file is read by run.sh and passed to the container via --env-file.
# NEVER commit your .env file.

# --- Anthropic API (direct) ---
ANTHROPIC_API_KEY=

# --- AWS Bedrock (uncomment if using Bedrock instead) ---
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# --- GitHub (optional, for PR workflows) ---
# GITHUB_TOKEN=

# --- OpenAI / Codex (optional) ---
# OPENAI_API_KEY=
